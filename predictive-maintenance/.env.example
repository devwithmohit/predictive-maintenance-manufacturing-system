# =============================================================================
# Predictive Maintenance System — Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment.
#   cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# TimescaleDB / PostgreSQL
# ---------------------------------------------------------------------------
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=predictive_maintenance
DB_USER=pmuser
DB_PASSWORD=CHANGE_ME_db_password

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_ENDPOINT=http://minio:9000

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://mlflow:5000

# ---------------------------------------------------------------------------
# Inference API
# ---------------------------------------------------------------------------
# Comma-separated list of valid API keys
API_KEYS=CHANGE_ME_api_key_1,CHANGE_ME_api_key_2
ADMIN_API_KEYS=CHANGE_ME_admin_key

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ---------------------------------------------------------------------------
# Retraining Scheduler
# ---------------------------------------------------------------------------
RETRAIN_CRON_HOUR=2
RETRAIN_CRON_DAY_OF_WEEK=sun
RETRAIN_RUN_ON_STARTUP=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
# SERVICE_NAME is set per-container; do not override here

# ---------------------------------------------------------------------------
# Service Ports (informational — change in docker-compose.yml if needed)
# ---------------------------------------------------------------------------
# INFERENCE_API_PORT=8000
# ALERT_ENGINE_PORT=8001
# STREAM_PROCESSOR_METRICS_PORT=8002
# DASHBOARD_PORT=8501
# GRAFANA_PORT=3000
# MLFLOW_PORT=5000
# PROMETHEUS_PORT=9090
